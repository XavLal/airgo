{
  "expo": {
    "name": "AirGoCC",
    "slug": "airgocc",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "icon": "./assets/icon.png",
      "bundleIdentifier": "com.anonymous.airgocc",
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "AirGoCC utilise votre position pour afficher les aires proches de vous.",
        "NSPhotoLibraryUsageDescription": "AirGoCC a besoin de votre galerie pour ajouter des photos aux aires."
      }
    },
    "android": {
      "icon": "./assets/icon.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.WAKE_LOCK",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.WAKE_LOCK"
      ],
      "package": "com.anonymous.airgocc"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "airgocc",
    "plugins": [
      "expo-router",
      "expo-location",
      "expo-localization",
      "expo-image-picker",
      "expo-background-fetch",
      [
        "expo-sqlite",
        {
          "customBuildFlags": "-DSQLITE_ENABLE_RTREE=1"
        }
      ]
    ]
  }
}